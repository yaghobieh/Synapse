{
  "manifest_version": 3,
  "name": "Synapse DevTools",
  "version": "1.0.0",
  "description": "DevTools extension for Synapse state management - view actions, state, and make API calls",
  "icons": {
    "16": "public/icons/icon16.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "devtools_page": "src/devtools.html",
  "background": {
    "service_worker": "dist/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "dist/content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "dist/inject.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}