{
  "compilerOptions": {
    "moduleResolution": "node",
    "target": "ES2020",
    "module": "CommonJS",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist/cli",
    "rootDir": "./cli",
    "declaration": false,
    "resolveJsonModule": true
  },
  "include": ["cli/**/*"],
  "exclude": ["node_modules", "dist"]
}

