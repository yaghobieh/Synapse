{
  "manifest_version": 3,
  "name": "Synapse DevTools",
  "version": "1.2.0",
  "description": "Developer tools for Synapse state management. Inspect, debug, and time-travel through your React application state.",
  "author": "John Yaghobieh",
  "homepage_url": "https://forgestack.dev/synapse",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "devtools_page": "devtools.html",
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.js", "panel.css", "inject.js"],
      "matches": ["<all_urls>"]
    }
  ]
}

